{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.py" },
    { "source": "/pilltrack", "destination": "/frontend/pilltrack.html" },
    { "source": "/favicon.svg", "destination": "/frontend/favicon.svg" },
    { "source": "/", "destination": "/frontend/index.html" },
    { "source": "/css/(.*)", "destination": "/frontend/css/$1" },
    { "source": "/js/(.*)", "destination": "/frontend/js/$1" },
    { "source": "/images/(.*)", "destination": "/frontend/images/$1" },
    { "source": "/templates/(.*)", "destination": "/frontend/templates/$1" },
    { "source": "/(.*)", "destination": "/frontend/$1" }
  ]
}
